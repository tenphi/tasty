{
  "name": "@tenphi/tasty",
  "version": "0.9.0",
  "description": "A design-system-integrated styling system and DSL for concise, state-aware UI styling",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./static": {
      "types": "./dist/static/index.d.ts",
      "import": "./dist/static/index.js",
      "default": "./dist/static/index.js"
    },
    "./babel-plugin": {
      "types": "./dist/zero/babel.d.ts",
      "import": "./dist/zero/babel.js",
      "default": "./dist/zero/babel.js"
    },
    "./zero": {
      "types": "./dist/zero/index.d.ts",
      "import": "./dist/zero/index.js",
      "default": "./dist/zero/index.js"
    },
    "./next": {
      "types": "./dist/zero/next.d.ts",
      "import": "./dist/zero/next.js",
      "default": "./dist/zero/next.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./ssr": {
      "types": "./dist/ssr/index.d.ts",
      "import": "./dist/ssr/index.js",
      "default": "./dist/ssr/index.js"
    },
    "./ssr/next": {
      "types": "./dist/ssr/next.d.ts",
      "import": "./dist/ssr/next.js",
      "default": "./dist/ssr/next.js"
    },
    "./ssr/astro": {
      "types": "./dist/ssr/astro.d.ts",
      "import": "./dist/ssr/astro.js",
      "default": "./dist/ssr/astro.js"
    },
    "./tasty.config": "./tasty.config.ts"
  },
  "files": [
    "dist",
    "docs",
    "tasty.config.ts"
  ],
  "sideEffects": [
    "./dist/ssr/index.js",
    "./dist/ssr/next.js",
    "./dist/ssr/astro.js"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "size": "size-limit",
    "prepublishOnly": "pnpm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tenphi/tasty.git"
  },
  "keywords": [
    "css-in-js",
    "styling",
    "design-system",
    "react",
    "state-aware",
    "zero-runtime",
    "babel-plugin",
    "typescript",
    "dsl"
  ],
  "author": "Andrey Yamanov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tenphi/tasty/issues"
  },
  "homepage": "https://github.com/tenphi/tasty#readme",
  "peerDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/helper-plugin-utils": "^7.24.0",
    "@babel/types": "^7.24.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "@babel/helper-plugin-utils": {
      "optional": true
    },
    "@babel/types": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "csstype": "^3.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@size-limit/esbuild": "^12.0.0",
    "@size-limit/file": "^12.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/babel__helper-plugin-utils": "^7.10.3",
    "@types/node": "^25.3.2",
    "@types/react": "^19.0.0",
    "@vitest/runner": "^4.0.18",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "size-limit": "^12.0.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.29.3",
  "size-limit": [
    {
      "name": "main (import *)",
      "path": "dist/index.js",
      "import": "*",
      "limit": "47 kB"
    },
    {
      "name": "core (import *)",
      "path": "dist/core/index.js",
      "import": "*",
      "limit": "45 kB"
    },
    {
      "name": "static",
      "path": "dist/static/index.js",
      "import": "*",
      "limit": "2 kB"
    },
    {
      "name": "zero",
      "path": "dist/zero/index.js",
      "import": "*",
      "ignore": [
        "fs",
        "path",
        "crypto"
      ],
      "limit": "27 kB"
    },
    {
      "name": "babel-plugin",
      "path": "dist/zero/babel.js",
      "import": "*",
      "ignore": [
        "fs",
        "path",
        "crypto"
      ],
      "limit": "37 kB"
    }
  ]
}