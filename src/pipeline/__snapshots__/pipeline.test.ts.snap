exports[`_ fallback floor > persists the floor alongside a "" default and other states 1`] = `
[
  {
    "declarations": "color: gray;",
    "selector": ".btn",
  },
  {
    "declarations": "color: black;",
    "selector": ".btn:where(:not([data-pressed]))",
  },
  {
    "declarations": "color: red;",
    "selector": ".btn:where([data-pressed])",
  },
]
`;

exports[`_ fallback floor > should emit a bare default + positive override for the scroll-state case 1`] = `
[
  {
    "declarations": "inset: 0 auto auto auto;",
    "selector": ".component",
  },
  {
    "atRules": [
      "@container scroll-state(scrolled: block-end)",
      "@supports (container-type: scroll-state)",
    ],
    "declarations": "inset: -10px auto auto auto;",
    "selector": ".component",
  },
]
`;
