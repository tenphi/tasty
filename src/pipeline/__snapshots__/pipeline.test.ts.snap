// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@supports queries snapshot tests > should eliminate impossible @supports combinations 1`] = `
[
  {
    "atRules": [
      "@supports (not selector(:has(*))) and (display: grid)",
    ],
    "declarations": "display: grid;",
    "selector": ".component",
  },
  {
    "atRules": [
      "@supports (display: grid) and selector(:has(*))",
    ],
    "declarations": "display: flex;",
    "selector": ".component",
  },
  {
    "atRules": [
      "@supports (not (display: grid))",
    ],
    "declarations": "display: inline-block;",
    "selector": ".component",
  },
]
`;

exports[`@supports queries snapshot tests > should keep the not-supported path free of guarded feature queries 1`] = `
[
  {
    "atRules": [
      "@supports (not (container-type: scroll-state))",
    ],
    "declarations": "display: block;",
    "selector": ".component",
  },
  {
    "atRules": [
      "@container (not scroll-state(scrolled: block-end))",
      "@supports (container-type: scroll-state)",
    ],
    "declarations": "display: block;",
    "selector": ".component",
  },
  {
    "atRules": [
      "@container scroll-state(scrolled: block-end)",
      "@supports (container-type: scroll-state)",
    ],
    "declarations": "display: grid;",
    "selector": ".component",
  },
]
`;

