exports[`@supports queries snapshot tests > should render @supports with modifier - 2 exclusive rules 1`] = `
[
  {
    "atRules": [
      "@supports (not selector(:has(*)))",
    ],
    "declarations": "display: block;",
    "selector": ".demo",
  },
  {
    "atRules": [
      "@supports selector(:has(*))",
    ],
    "declarations": "display: block;",
    "selector": ".demo:where(:not(:has(> [data-element="Icon"])))",
  },
  {
    "atRules": [
      "@supports selector(:has(*))",
    ],
    "declarations": "display: grid;",
    "selector": ".demo:where(:has(> [data-element="Icon"]))",
  },
]
`;

exports[`@supports queries snapshot tests > should render @supports with modifiers 1`] = `
